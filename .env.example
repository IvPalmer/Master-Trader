# Binance API credentials — real-money bot deployment
#
# Copy to .env (which is gitignored) and fill in. NEVER commit .env.
#
# Required permissions on the Binance API key:
#   - Enable Reading              (needed for balance + trade history)
#   - Enable Spot & Margin Trading (needed to place orders)
#   - Enable Withdrawals          OFF — do NOT enable, limits blast radius of key leak
#   - Enable Futures              OFF — no futures bots
#   - IP whitelist: your current IP (find with: curl ifconfig.me)

BINANCE_API_KEY=paste_your_api_key_here
BINANCE_API_SECRET=paste_your_secret_here
