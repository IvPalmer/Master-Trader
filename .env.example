# Master Trader — live deployment credentials
#
# Copy to .env (gitignored). NEVER commit .env. NEVER share contents in chat.
#
# ── Binance API key (spot trading, withdrawals OFF, IP-whitelisted) ─────────
# Required scopes:
#   - Enable Reading
#   - Enable Spot & Margin Trading
#   - Enable Withdrawals          OFF
#   - Enable Futures              OFF
#   - Enable Universal Transfer   OFF
#   - IP whitelist: your current IP (find with: curl ifconfig.me)
#
# Both name pairs must be populated. BINANCE_* is read by check_balance.py.
# FREQTRADE__EXCHANGE__* is consumed by Freqtrade via its env-substitution
# system (FREQTRADE__<SECTION>__<KEY> overrides the JSON config). They hold
# the same values.
BINANCE_API_KEY=paste_your_api_key_here
BINANCE_API_SECRET=paste_your_secret_here
FREQTRADE__EXCHANGE__KEY=paste_your_api_key_here
FREQTRADE__EXCHANGE__SECRET=paste_your_secret_here

# ── Freqtrade local API + JWT (replaces freqtrader/mastertrader defaults) ───
# Generate with:
#   python3 -c "import secrets,string; print('user=ft_'+''.join(secrets.choice(string.ascii_letters+string.digits) for _ in range(12))); print('pw='+''.join(secrets.choice(string.ascii_letters+string.digits) for _ in range(32))); print('jwt='+secrets.token_urlsafe(48))"
FREQTRADE__API_SERVER__USERNAME=ft_generate_me
FREQTRADE__API_SERVER__PASSWORD=generate_me_32_chars
FREQTRADE__API_SERVER__JWT_SECRET_KEY=generate_me_url_safe
