# Insiders Scalp prototype: data + secrets live under _local/ (never commit).
# Code files (parser.py, simulator.py, weex.py) ARE tracked — they hold the
# parser/simulator/price-walker that runs the offline replay.
ft_userdata/insiders_bridge/_local/*
!ft_userdata/insiders_bridge/_local/parser.py
!ft_userdata/insiders_bridge/_local/simulator.py
!ft_userdata/insiders_bridge/_local/weex.py
ft_userdata/insiders_bridge/out/

# Insiders listener env + secrets (.env.example is the template, .env is per-deployment)
ft_userdata/insiders_bridge/.env
ft_userdata/insiders_bridge/*.session
ft_userdata/insiders_bridge/secrets/

