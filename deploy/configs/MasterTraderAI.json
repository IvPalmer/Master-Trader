{
    "dry_run": true,
    "dry_run_wallet": 1000,
    "cancel_open_orders_on_exit": false,
    "trading_mode": "spot",
    "margin_mode": "",
    "stake_currency": "USDT",
    "stake_amount": "unlimited",
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "",
    "max_open_trades": 5,
    "amount_reserve_percent": 0.05,
    "timeframe": "5m",
    "unfilledtimeout": {
        "entry": 10,
        "exit": 10,
        "exit_timeout_count": 0,
        "unit": "minutes"
    },
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },
    "exchange": {
        "name": "binance",
        "key": "",
        "secret": "",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "BTC/USDT",
            "ETH/USDT",
            "SOL/USDT",
            "XRP/USDT",
            "DOGE/USDT",
            "BNB/USDT",
            "ADA/USDT",
            "AVAX/USDT",
            "LINK/USDT",
            "NEAR/USDT"
        ],
        "pair_blacklist": [
            ".*BULL/USDT",
            ".*BEAR/USDT",
            ".*UP/USDT",
            ".*DOWN/USDT",
            "USDC/USDT",
            "BUSD/USDT",
            "DAI/USDT",
            "TUSD/USDT",
            "FDUSD/USDT",
            ".*_PERP"
        ]
    },
    "pairlists": [
        {
            "method": "StaticPairList"
        }
    ],
    "freqai": {
        "enabled": true,
        "purge_old_models": 4,
        "train_period_days": 30,
        "backtest_period_days": 7,
        "identifier": "lgbm-spot-v1",
        "live_retrain_hours": 8,
        "expiration_hours": 16,
        "continual_learning": false,
        "fit_live_predictions_candles": 300,
        "feature_parameters": {
            "include_timeframes": [
                "5m",
                "15m",
                "1h"
            ],
            "include_corr_pairlist": [
                "BTC/USDT",
                "ETH/USDT"
            ],
            "label_period_candles": 20,
            "include_shifted_candles": 2,
            "indicator_periods_candles": [
                10,
                20
            ],
            "weight_factor": 0.9,
            "principal_component_analysis": false,
            "use_SVM_to_remove_outliers": true,
            "DI_threshold": 0.9,
            "use_DBSCAN_to_remove_outliers": false,
            "noise_standard_deviation": 0.03,
            "outlier_protection_percentage": 30,
            "reverse_train_test_order": false,
            "shuffle_after_split": false,
            "buffer_train_data_candles": 0
        },
        "data_split_parameters": {
            "test_size": 0.25,
            "shuffle": false
        },
        "model_training_parameters": {
            "n_estimators": 800,
            "learning_rate": 0.02,
            "n_jobs": -1
        }
    },
    "webhook": {
        "enabled": true,
        "url": "http://host.docker.internal:8088/webhooks/freqtrade",
        "webhookentry": {
            "type": "entry",
            "pair": "{pair}",
            "stake_amount": "{stake_amount}",
            "stake_currency": "{stake_currency}",
            "limit": "{limit}",
            "open_rate": "{open_rate}",
            "order_type": "{order_type}",
            "direction": "{direction}",
            "leverage": "{leverage}"
        },
        "webhookentrycancel": {
            "type": "entry_cancel",
            "pair": "{pair}",
            "reason": "{reason}"
        },
        "webhookentryfill": {
            "type": "entry_fill",
            "pair": "{pair}",
            "stake_amount": "{stake_amount}",
            "stake_currency": "{stake_currency}",
            "open_rate": "{open_rate}",
            "order_type": "{order_type}",
            "direction": "{direction}",
            "leverage": "{leverage}"
        },
        "webhookexit": {
            "type": "exit",
            "pair": "{pair}",
            "profit_ratio": "{profit_ratio}",
            "profit_amount": "{profit_amount}",
            "stake_currency": "{stake_currency}",
            "open_rate": "{open_rate}",
            "close_rate": "{close_rate}",
            "exit_reason": "{exit_reason}",
            "direction": "{direction}",
            "duration": "{duration}"
        },
        "webhookexitcancel": {
            "type": "exit_cancel",
            "pair": "{pair}",
            "reason": "{reason}"
        },
        "webhookexitfill": {
            "type": "exit_fill",
            "pair": "{pair}",
            "profit_ratio": "{profit_ratio}",
            "profit_amount": "{profit_amount}",
            "stake_currency": "{stake_currency}",
            "open_rate": "{open_rate}",
            "close_rate": "{close_rate}",
            "exit_reason": "{exit_reason}",
            "direction": "{direction}",
            "duration": "{duration}"
        },
        "webhookstatus": {
            "type": "status",
            "status": "{status}"
        }
    },
    "telegram": {
        "enabled": false,
        "token": "",
        "chat_id": ""
    },
    "api_server": {
        "enabled": true,
        "listen_ip_address": "0.0.0.0",
        "listen_port": 8080,
        "verbosity": "error",
        "enable_openapi": true,
        "jwt_secret_key": "CHANGE-ME-use-a-random-secret",
        "CORS_origins": [
            "http://localhost:8080",
            "http://localhost:8087"
        ],
        "username": "freqtrader",
        "password": "CHANGE-ME"
    },
    "bot_name": "MasterTraderAI",
    "initial_state": "running",
    "force_entry_enable": false,
    "internals": {
        "process_throttle_secs": 5
    },
    "db_url": "sqlite:////freqtrade/user_data/tradesv3.dryrun.MasterTraderAI.sqlite"
}