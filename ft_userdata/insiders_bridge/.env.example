# ft-insiders-listener env template.
#
# Copy to .env (gitignored). Each deployment (ours / Eduardo's) needs its
# OWN .env, its OWN .session file, its OWN event store volume, its OWN
# Binance API key. The container image is the same; only this file differs.

# Telethon credentials (from my.telegram.org). Same for everyone — these
# identify the *app* (our listener app), not the user.
INSIDERS_TG_API_ID=
INSIDERS_TG_API_HASH=

# Path to the .session file INSIDE the container. Mount the actual file
# as a read-only secret to /run/secrets/insiders.session in compose.
INSIDERS_TG_SESSION=/run/secrets/insiders.session

# Channel/group ID. Negative for supergroup. Same value for both deployments
# in phase 1 (we and Eduardo both source from the same group).
INSIDERS_TG_CHANNEL_ID=-1003881583689

# Receiver URL (where to POST classified events).
INSIDERS_RECEIVER_URL=http://insiders-receiver:8089/event

# Persistent event store path INSIDE container. Mount a per-deployment
# named volume so the two deployments' state stays separate.
INSIDERS_EVENT_STORE=/var/lib/insiders/events.sqlite

# Heartbeat interval in seconds. 45 = "within a minute" revocation
# detection holds even after one missed cycle. Lower = faster detection,
# more API/POST volume.
INSIDERS_HEARTBEAT_SEC=45

# Instance ID — tags every log line, every alert, every order. MUST differ
# between deployments. Examples: "palmer-prod", "eduardo".
INSIDERS_INSTANCE_ID=palmer-prod
