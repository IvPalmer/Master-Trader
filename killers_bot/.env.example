# Copy to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# From my.telegram.org → API development tools
KILLERS_TG_API_ID=
KILLERS_TG_API_HASH=

# Path to .session inside the container (mounted from ./secrets/killers.session)
KILLERS_TG_SESSION=/run/secrets/killers.session

# Channel username — observer.py resolves to a numeric id on first run
KILLERS_TG_CHANNEL_USERNAME=BinanceKillers_FreeSignal

# Optional: override numeric channel id (if you've already resolved it once)
# KILLERS_TG_CHANNEL_ID=-1001234567890

# Claude CLI — must be installed and authenticated (Max subscription)
KILLERS_CLAUDE_BINARY=claude
# KILLERS_CLAUDE_MODEL=claude-sonnet-4-6  # optional model override
KILLERS_CLAUDE_TIMEOUT_SEC=12

KILLERS_DB=/var/lib/killers/state.sqlite
KILLERS_HEARTBEAT_SEC=60
